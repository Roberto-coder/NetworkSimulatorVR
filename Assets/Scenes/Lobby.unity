  modulos:
  - toggle: {fileID: 1993271461}
    data:
      titulo: Tutorial
      descripcion: " Familiar\xEDzate con los controles, interacci\xF3n y entorno
        del simulador antes de comenzar los m\xF3dulos."
      objetivos: "* Aprender controles VR\n* Interactuar con objetos\n* Navegar en
        el entorno\n* Prepararse para los m\xF3dulos"
      imagen: {fileID: 21300000, guid: 87805fa2e196d415b84396f8e984abcf, type: 3}
      escena: 
  - toggle: {fileID: 1918647474}
    data:
      titulo: " M\xF3dulo 1 \u2013 Cableado"
      descripcion: ' Aprende a manipular cables UTP, realizar conexiones RJ45 y verificar
        su funcionamiento dentro de un entorno interactivo. '
      objetivos: "* Identificar los componentes del cable UTP\n* Aplicar el est\xE1ndar
        T568B\n* Realizar conexiones correctas\n* Validar cables con tester"
      imagen: {fileID: 21300000, guid: 4a924c9172e4ad04e972fe0a7eadbab9, type: 3}
      escena: Lobby
  - toggle: {fileID: 1358210251}
    data:
      titulo: " M\xF3dulo 2 \u2013 Rack y Switch"
      descripcion: ' Configura dispositivos en rack, organiza cableado y aprende
        a interactuar con switches de red.'
      objetivos: "* Identificar los componentes del cable UTP\n* Aplicar el est\xE1ndar
        T568B\n* Realizar conexiones correctas\n* Validar cables con tester"
      imagen: {fileID: 21300000, guid: c5a02d41f0fa4394cbfbbfe2d813f13f, type: 3}
      escena: 
  - toggle: {fileID: 1746700772}
    data:
      titulo: " M\xF3dulo 3 \u2013 Diagn\xF3stico de red"
      descripcion: Detecta fallas en la red, reconecta dispositivos y valida conectividad
        mediante herramientas como ping.
      objetivos: '* Identificar fallas de red

        * Reconectar cables correctamente

        *
        Ejecutar pruebas de conectividad

        * Resolver problemas comunes'
      imagen: {fileID: 21300000, guid: f8c38088c69280141b3a9f5e8f19df97, type: 3}
      escena: 
  moduleCardPrefab: {fileID: 7304406178615403290, guid: d813e99468eb43f44ae1934141fb9ce9, type: 3}
